# Environment Variables for OCR Workbench

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars-recommended
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Database Configuration
DATABASE_URL=sqlite:///./ocr_workbench.db

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# API Configuration
API_TITLE=OCR Workbench API
API_VERSION=1.0.0

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8501

# Logging Configuration
LOG_DIR=logs
LOG_RETENTION_DAYS=30

# File Upload Configuration
MAX_FILE_SIZE_MB=100

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# Pagination
DEFAULT_PAGE_SIZE=50

# Processing
MAX_CONCURRENT_WORKERS=5
